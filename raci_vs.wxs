<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX Toolset v4 installer for RACI-VS Manager.
  Prerequisites: run build.bat first so dist\RACI-VS\ exists.
  Built by: wix build raci_vs.wxs -ext WixToolset.UI.wixext -arch x64 -o Output\RACI-VS_Setup.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="RACI-VS Manager"
           Language="1033"
           Version="1.0.0.0"
           Manufacturer="Your Company"
           UpgradeCode="{0E447C8C-0B5A-4C78-AB04-B1F8672D86FC}"
           Scope="perUser">

    <MajorUpgrade DowngradeErrorMessage="A newer version of RACI-VS Manager is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Install directory picker wizard: Welcome -> Dir -> Install -> Finish -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLDIR" />

    <Feature Id="Complete">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- Install directory: %LOCALAPPDATA%\RACI-VS Manager -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLDIR" Name="RACI-VS Manager" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="RACI-VS Manager">
        <Component Id="StartMenuShortcut">
          <Shortcut Id="StartMenuEntry"
                    Name="RACI-VS Manager"
                    Description="RACI-VS Responsibility Matrix Manager"
                    Target="[INSTALLDIR]RACI-VS.exe"
                    WorkingDirectory="INSTALLDIR" />
          <RemoveFolder Id="RemoveProgramMenuDir" Directory="ProgramMenuDir" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\RACI-VS" Name="StartMenu"
                         Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut">
        <Shortcut Id="DesktopEntry"
                  Name="RACI-VS Manager"
                  Description="RACI-VS Responsibility Matrix Manager"
                  Target="[INSTALLDIR]RACI-VS.exe"
                  WorkingDirectory="INSTALLDIR" />
        <RegistryValue Root="HKCU" Key="Software\RACI-VS" Name="Desktop"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

  </Package>
</Wix>
