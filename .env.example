# ── Database connection ───────────────────────────────────────────────────────
#
# Copy this file to .env and fill in the values for your environment.
# The .env file is gitignored and must never be committed.
#
# Option A – Local SQLite (default when DATABASE_URL is not set)
# No .env file needed; the app creates raci_vs.db automatically.
#
# Option B – Azure SQL with SQL authentication (username + password)
# DATABASE_URL=mssql+pyodbc://USERNAME:PASSWORD@YOUR_SERVER.database.windows.net/raci_vs?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
#
# Option C – Azure SQL with Azure AD / Entra ID (recommended; no shared secret)
# Requires the user to be signed in to their M365 account on this machine.
# IT must grant the user's Entra ID account db_datareader + db_datawriter on the database.
# DATABASE_URL=mssql+pyodbc://@YOUR_SERVER.database.windows.net/raci_vs?driver=ODBC+Driver+18+for+SQL+Server&Authentication=ActiveDirectoryIntegrated&Encrypt=yes

DATABASE_URL=
